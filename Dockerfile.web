# ─── Stage 0: prefetch ONNX models ───────────────────────────────────────────
# Download only the q4f16 ONNX weights + JSON configs so the runtime image
# can serve them as static assets without any 3rd-party network dependency.
#
# Models must match SUPPORTED_LOCAL_MODELS in localModelStore.ts and the
# local-webgpu provider entries in providerStore.ts. All three repos publish
# a self-contained onnx/model_q4f16.onnx file that transformers.js loads
# when dtype:"q4f16" is requested.
FROM python:3.12-slim AS model-downloader

# Optional: pass --build-arg HF_TOKEN=<token> for gated/private repos.
ARG HF_TOKEN=""

RUN pip install --no-cache-dir "huggingface_hub"

# Llama 3.2 1B Instruct (~1.24 GB at q4f16) — well-tested in transformers.js
# WebGPU examples; text-only, fits on M1/16 GB.
RUN python3 -c "\
import os; \
from huggingface_hub import snapshot_download; \
token = os.environ.get('HF_TOKEN') or None; \
snapshot_download(repo_id='onnx-community/Llama-3.2-1B-Instruct-q4f16', allow_patterns=['*.json', 'onnx/*q4f16*'], local_dir='/models/onnx-community/Llama-3.2-1B-Instruct-q4f16', token=token)" \
  && echo "Llama model downloaded." || echo "WARNING: Llama model download failed, models will be fetched at runtime."

# SmolLM2 1.7B Instruct (~1.11 GB at q4f16) — compact HuggingFace Smol model.
RUN python3 -c "\
import os; \
from huggingface_hub import snapshot_download; \
token = os.environ.get('HF_TOKEN') or None; \
snapshot_download(repo_id='HuggingFaceTB/SmolLM2-1.7B-Instruct', allow_patterns=['*.json', 'onnx/*q4f16*'], local_dir='/models/HuggingFaceTB/SmolLM2-1.7B-Instruct', token=token)" \
  && echo "SmolLM2 model downloaded." || echo "WARNING: SmolLM2 model download failed, models will be fetched at runtime."

# Qwen2.5 1.5B Instruct (~1.22 GB at q4f16) — compact instruction-tuned model.
RUN python3 -c "\
import os; \
from huggingface_hub import snapshot_download; \
token = os.environ.get('HF_TOKEN') or None; \
snapshot_download(repo_id='onnx-community/Qwen2.5-1.5B-Instruct', allow_patterns=['*.json', 'onnx/*q4f16*'], local_dir='/models/onnx-community/Qwen2.5-1.5B-Instruct', token=token)" \
  && echo "Qwen model downloaded." || echo "WARNING: Qwen model download failed, models will be fetched at runtime."

# ─── Stage 1: build the Vite app ────────────────────────────────────────────
FROM node:22-alpine AS builder

RUN corepack enable && corepack prepare pnpm@latest --activate

WORKDIR /app

# Copy workspace manifests first (layer-cache friendly)
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml ./
COPY packages/shared-types/package.json ./packages/shared-types/
COPY apps/web/package.json ./apps/web/
# Stub proxy so pnpm doesn't fail on workspace resolution
COPY apps/proxy/package.json ./apps/proxy/

RUN pnpm install --frozen-lockfile

# Copy full source
COPY tsconfig.base.json ./
COPY packages/shared-types/ ./packages/shared-types/
COPY apps/web/ ./apps/web/

# Bake the local model base URL into the bundle so the WebGPU worker loads
# models from the pre-fetched static assets instead of HuggingFace at runtime.
RUN VITE_LOCAL_MODEL_BASE_URL=/models pnpm --filter @zenon/web build

# ─── Stage 2: serve with nginx ───────────────────────────────────────────────
FROM nginx:1.27-alpine AS runtime

# Generate a self-signed TLS cert at build time.
# OPFS, SharedArrayBuffer, and Web Speech API all require a secure context.
RUN apk add --no-cache openssl && \
    mkdir -p /etc/nginx/ssl && \
    openssl req -x509 -nodes -days 3650 -newkey rsa:2048 \
      -keyout /etc/nginx/ssl/server.key \
      -out  /etc/nginx/ssl/server.crt \
      -subj "/CN=zenon-local"

COPY --from=builder /app/apps/web/dist /usr/share/nginx/html
# Serve pre-fetched ONNX models as static assets
COPY --from=model-downloader /models /usr/share/nginx/html/models
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80 443
