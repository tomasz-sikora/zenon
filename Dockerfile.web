# ─── Stage 0: prefetch ONNX models ───────────────────────────────────────────
# Download Ministral 3B Instruct (text-only ONNX components).
# Files downloaded:
#   onnx/embed_tokens_fp16.onnx + .onnx_data  (~805 MB)
#   onnx/decoder_model_merged_q4f16.onnx + .onnx_data  (~2 GB)
# Total: ~2.8 GB. No vision_encoder downloaded (text-only inference).
#
# dtype used by the worker: { embed_tokens: 'fp16', decoder_model_merged: 'q4f16' }
FROM python:3.12-slim AS model-downloader

# Optional: pass --build-arg HF_TOKEN=<token> for gated/private repos.
ARG HF_TOKEN=""

RUN pip install --no-cache-dir "huggingface_hub"

# Ministral 3B Instruct — text-only components (embed_tokens fp16 + decoder q4f16, ~2.8 GB).
RUN python3 -c "\
import os; \
from huggingface_hub import snapshot_download; \
token = os.environ.get('HF_TOKEN') or None; \
snapshot_download(\
repo_id='mistralai/Ministral-3-3B-Instruct-2512-ONNX', \
allow_patterns=[\
'*.json', \
'*.jinja', \
'onnx/embed_tokens_fp16.onnx', \
'onnx/embed_tokens_fp16.onnx_data', \
'onnx/decoder_model_merged_q4f16.onnx', \
'onnx/decoder_model_merged_q4f16.onnx_data'\
], \
local_dir='/models/mistralai/Ministral-3-3B-Instruct-2512-ONNX', \
token=token)" \
  && echo "Ministral 3B text-only files downloaded." || echo "WARNING: Ministral 3B text-only download failed."

# Ministral 3B — vision encoder q4 (~271 MB). Required by Mistral3ForConditionalGeneration
# even when running text-only inference (transformers.js loads all submodels on init).
RUN python3 -c "\
import os; \
from huggingface_hub import snapshot_download; \
token = os.environ.get('HF_TOKEN') or None; \
snapshot_download(\
repo_id='mistralai/Ministral-3-3B-Instruct-2512-ONNX', \
allow_patterns=[\
'onnx/vision_encoder_q4.onnx', \
'onnx/vision_encoder_q4.onnx_data'\
], \
local_dir='/models/mistralai/Ministral-3-3B-Instruct-2512-ONNX', \
token=token)" \
  && echo "Ministral 3B vision encoder downloaded." || echo "WARNING: Vision encoder download failed, models will be fetched at runtime."

# ─── Stage 1: build the Vite app ────────────────────────────────────────────
FROM node:22-alpine AS builder

RUN corepack enable && corepack prepare pnpm@latest --activate

WORKDIR /app

# Copy workspace manifests first (layer-cache friendly)
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml ./
COPY packages/shared-types/package.json ./packages/shared-types/
COPY apps/web/package.json ./apps/web/
# Stub proxy so pnpm doesn't fail on workspace resolution
COPY apps/proxy/package.json ./apps/proxy/

RUN pnpm install --frozen-lockfile

# Copy full source
COPY tsconfig.base.json ./
COPY packages/shared-types/ ./packages/shared-types/
COPY apps/web/ ./apps/web/

# Bake the local model base URL into the bundle so the WebGPU worker loads
# models from the pre-fetched static assets instead of HuggingFace at runtime.
RUN VITE_LOCAL_MODEL_BASE_URL=/models pnpm --filter @zenon/web build

# ─── Stage 2: serve with nginx ───────────────────────────────────────────────
FROM nginx:1.27-alpine AS runtime

# Generate a self-signed TLS cert at build time.
# OPFS, SharedArrayBuffer, and Web Speech API all require a secure context.
RUN apk add --no-cache openssl && \
    mkdir -p /etc/nginx/ssl && \
    openssl req -x509 -nodes -days 3650 -newkey rsa:2048 \
      -keyout /etc/nginx/ssl/server.key \
      -out  /etc/nginx/ssl/server.crt \
      -subj "/CN=zenon-local" \
      -addext "subjectAltName=DNS:*.local,DNS:localhost,IP:127.0.0.1"

COPY --from=builder /app/apps/web/dist /usr/share/nginx/html
# Serve pre-fetched ONNX models as static assets
COPY --from=model-downloader /models /usr/share/nginx/html/models
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80 443
