{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "composite": true,
    "tsBuildInfoFile": "./.turbo/tsconfig.tsbuildinfo",
    "types": ["vitest/globals", "vite/client"]
  },
  "include": ["src", "vite.config.ts"],
  "exclude": ["node_modules", "dist", "src/**/*.test.*", "src/**/*.spec.*", "src/test"]
}
